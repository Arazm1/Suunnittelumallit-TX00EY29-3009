<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ChatWindowController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

    <left>
        <ListView fx:id="userList" prefWidth="120.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets right="10.0"/>
            </BorderPane.margin>
        </ListView>
    </left>

    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <TextArea fx:id="messageHistory" editable="false" prefHeight="200.0" prefWidth="300.0" VBox.vgrow="ALWAYS" />
            
            <HBox spacing="10.0">
                <TextField fx:id="messageField" promptText="Type a message..." HBox.hgrow="ALWAYS" />
                <Button text="Send" onAction="#handleSend" />
            </HBox>
        </VBox>
    </center>
</BorderPane>